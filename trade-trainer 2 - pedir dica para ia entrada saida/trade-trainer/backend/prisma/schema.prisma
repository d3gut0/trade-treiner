// Schema do Trade Trainer
// Banco: Postgres
// Entidades: Asset, HistoricalCandle, Strategy, TrainingSession, SimulatedTrade, TradeJustification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Timeframe {
  M1
  M2
  M5
}

enum TradeDirection {
  COMPRA
  VENDA
}

enum TradeResult {
  GAIN
  LOSS
  ENCERRADO_TEMPO // sessao acabou antes do stop ser tocado
  ENCERRADO_MANUAL // usuario fechou manualmente
  EM_ANDAMENTO
}

enum SessionStatus {
  EM_ANDAMENTO
  FINALIZADA
}

enum AvaliacaoIAStatus {
  PENDENTE   // justificativa salva, ainda nao foi pedida avaliacao por IA
  AVALIADO   // IA respondeu com sucesso
  ERRO       // tentativa de avaliacao falhou (ex: rede, API key invalida)
}

enum CoachingTipStatus {
  PENDENTE   // ainda nao foi pedida nenhuma dica para este trade
  GERADO     // IA gerou a dica com sucesso
  ERRO       // tentativa de gerar a dica falhou
}

model Asset {
  id        String   @id @default(uuid())
  ticker    String   @unique // ex: PETR4.SA, VALE3.SA
  nome      String?
  createdAt DateTime @default(now())

  candles  HistoricalCandle[]
  sessions TrainingSession[]

  @@map("assets")
}

// Candle historico real, baixado via yahoo-finance2.
// Os indicadores (EMA9, EMA21, VWAP) sao pre-calculados e armazenados
// junto pra nao recalcular em toda requisicao de replay.
model HistoricalCandle {
  id        String    @id @default(uuid())
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id])
  timeframe Timeframe
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float

  ema9  Float?
  ema21 Float?
  vwap  Float?

  // indice sequencial dentro do lote baixado (facilita o replay ordenado)
  sequenceIndex Int

  createdAt DateTime @default(now())

  @@unique([assetId, timeframe, timestamp])
  @@index([assetId, timeframe, sequenceIndex])
  @@map("historical_candles")
}

// Banco de estrategias cadastradas pelo usuario
model Strategy {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  // criterios em JSON livre, ex:
  // { "indicadores": ["EMA9","EMA21"], "regra": "cruzamento", "confirmacao": [...] }
  criterios   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trades SimulatedTrade[]

  @@map("strategies")
}

model TrainingSession {
  id        String        @id @default(uuid())
  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id])
  timeframe Timeframe

  // janela de candles historicos usada nesta sessao (referencia por sequenceIndex)
  startSequenceIndex Int
  endSequenceIndex   Int
  totalCandles       Int // numero fixo de candles da sessao (ex: 30)

  // quantos candles o usuario ja revelou no replay manual
  candlesRevealed Int @default(1)

  status    SessionStatus @default(EM_ANDAMENTO)
  createdAt DateTime      @default(now())
  finishedAt DateTime?

  trades SimulatedTrade[]

  @@map("training_sessions")
}

model SimulatedTrade {
  id         String          @id @default(uuid())
  sessionId  String
  session    TrainingSession @relation(fields: [sessionId], references: [id])
  strategyId String?
  strategy   Strategy?       @relation(fields: [strategyId], references: [id])

  direction TradeDirection

  entryPrice Float
  stopGain   Float
  stopLoss   Float

  entrySequenceIndex Int // candle (sequenceIndex) em que a entrada foi feita
  exitSequenceIndex  Int?
  exitPrice          Float?

  result TradeResult @default(EM_ANDAMENTO)

  createdAt DateTime  @default(now())
  closedAt  DateTime?

  justification TradeJustification?
  coachingTip   CoachingTip?

  @@map("simulated_trades")
}

model TradeJustification {
  id      String         @id @default(uuid())
  tradeId String         @unique
  trade   SimulatedTrade @relation(fields: [tradeId], references: [id])

  // criterios marcados pelo usuario (checkboxes)
  criterioFechamentoContrario Boolean @default(false)
  criterioRompimentoReferencia Boolean @default(false)
  criterioMediaMudouDirecao   Boolean @default(false)

  textoLivre String?

  // status do ciclo de avaliacao por IA - permite salvar a justificativa
  // imediatamente e disparar a avaliacao por IA depois, em outro momento
  // (ex: revisitando o historico), em vez de forcar a chamada de IA na hora
  avaliacaoStatus AvaliacaoIAStatus @default(PENDENTE)
  avaliacaoErro   String? // mensagem de erro da ultima tentativa, se houver

  // resposta da IA (Google Gemini)
  avaliacaoIA       String? // texto do veredito
  criteriosConfirmadosIA Json? // { fechamentoContrario: bool|null, rompimentoReferencia: bool|null, mediaMudouDirecao: bool|null }
  gestaoRespeitada  Boolean? // se o stop nao foi alterado / segue a regra
  scoreIA           Int?    // 0-100, opcional
  avaliadoEm        DateTime? // quando a IA respondeu com sucesso pela ultima vez

  createdAt DateTime @default(now())

  @@map("trade_justifications")
}

// Dica de coaching gerada por IA sobre timing de entrada/saida de um trade
// especifico, considerando a estrategia vinculada (se houver). Independente
// da TradeJustification - pode ser pedida em qualquer momento, mesmo sem o
// usuario ter justificado o trade ainda.
model CoachingTip {
  id      String         @id @default(uuid())
  tradeId String         @unique
  trade   SimulatedTrade @relation(fields: [tradeId], references: [id])

  status CoachingTipStatus @default(PENDENTE)
  erro   String? // mensagem de erro da ultima tentativa, se houver

  // resposta da IA (Google Gemini), estruturada em JSON:
  // { entradaIdeal: { sequenceIndex, justificativa, comparacaoComEntradaReal },
  //   saidaIdeal: { sequenceIndex, justificativa, comparacaoComSaidaReal },
  //   resumo }
  conteudo Json?

  geradoEm  DateTime?
  createdAt DateTime @default(now())

  @@map("coaching_tips")
}
